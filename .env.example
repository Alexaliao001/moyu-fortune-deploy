# MoYu — production is static GH Pages (chillworks.ai) + light API on Render.

# PORT=3000
# HOST=0.0.0.0
# MOYU_CORS_ORIGINS=https://chillworks.ai,https://www.chillworks.ai,http://localhost:3000
# MOYU_DATA_DIR=./data

# Optional Turso persistence (free tier). Without these, JSON store is ephemeral on Render Free.
# LIBSQL_URL=libsql://your-db.turso.io
# LIBSQL_AUTH_TOKEN=
# DATABASE_URL=   # alias for LIBSQL_URL when using Turso

# Frontend build (gh-pages) — also see committed .env.production
# VITE_FULL_BACKEND=true
# VITE_MOYU_API_BASE=https://moyu-fortune.onrender.com
# Path B static-only (no Stripe/auth):
# VITE_STATIC_MODE=true
# VITE_MOYU_API_BASE=https://moyu-fortune.onrender.com

# Manus publish placeholders (do not commit real values)
# VITE_ANALYTICS_ENDPOINT=
# VITE_ANALYTICS_WEBSITE_ID=
# VITE_OAUTH_PORTAL_URL=
# VITE_APP_ID=
